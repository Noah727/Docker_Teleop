  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TeleopInstructionBoard
  createInstructionBoard: 1
  rebuildInstructionBoardFromSettings: 0
  boardName: Teleop_Button_Instructions
  boardWorldPosition: {x: 1, y: 1.3, z: 1.8}
  boardWorldEuler: {x: 0, y: 90, z: 0}
  boardWorldScale: {x: 0.00155, y: 0.00155, z: 0.00155}
  boardSize: {x: 620, y: 580}
  backgroundColor: {r: 0.08, g: 0.07, b: 0.055, a: 0.88}
  accentColor: {r: 0.9, g: 0.55, b: 0.25, a: 1}
  titleColor: {r: 1, g: 0.88, b: 0.66, a: 1}
  textColor: {r: 0.96, g: 0.92, b: 0.84, a: 1}
  title: ROBOT CONTROLS
  instructions: 'RIGHT CONTROLLER

    Grip hold: engage robot teleop

    Trigger
    tap: toggle gripper open / close

    A hold: rotation mode

    B tap: reset
    robot + table objects

    Thumbstick press: clutch; release to recenter hand
    reference


    LEFT CONTROLLER

    X tap: start / stop wrist-camera recording

    Y
    tap: switch hand-pose / thumbstick mode


    THUMBSTICK MODE

    Left stick:
    forward/back + left/right

    Left trigger / grip: up / down

    Right stick:
    rotate wrist


    CONTROL PANEL

    Release right grip, point left controller
    at panel,

    hold left trigger to drag it.'
