    </model>

    <model name="Sync_Plate_A">
      <static>true</static>
      <pose>0.58938 0.35221 0.00250 0 0 0</pose>
      <link name="plate_link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.100 0.100 0.005</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
