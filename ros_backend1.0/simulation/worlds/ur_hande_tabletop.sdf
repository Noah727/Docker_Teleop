          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.010</radius>
              <length>0.048</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.10 0.70 0.18 1</ambient>
