            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="Sync_Plate_B">
      <static>true</static>
      <pose>0.59638 0.01721 0.00250 0 0 0</pose>
      <link name="plate_link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.100 0.100 0.005</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
